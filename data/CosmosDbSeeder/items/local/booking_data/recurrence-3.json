      //small UI concern but not that impactful (pros > cons)
      "from": "2026-07-22",
      "until": "2026-10-06"
    }
  ],
  
  "overrideDates": [
    {
      //on creation of an edit occurrence, could offer user to link/unlink from parent recurrence
      //this means that it splits and clones data into its own session and adds a new exclusionDate to this rule
      //OR
      //adds the override below that responds to parent changes as is listed as atomic patches/static changes
      "date": "2026-08-30",
      
      //logic if linked, COMPARE new session to parent, and store any atomic changes and static changes, then save!
      
      "sessions": [
        {
          //if these props are undefined, use parent data!
          "from": "10:00",
          "until": "15:00",
          "slotLength": 10,
          //dont want capacity to be atomic as it could introduce silly edge cases :D 
          //i.e. capacity is one fewer than parent, then parent goes down to 1 capacity!
          "capacity": 2,
          //if these props ARE defined then use this data instead of parent...
          //dont want these atomic patches, as they dont make sense to 'adjust' on parent change
          //i.e. time change forward 1 hour, won't want a reaction!
          //i.e. capcity of parent changes, but this override was defined with a specific capacity (when created) - so dont want to react to parent change!
          //i.e. from, until and slot length was defined as different to parent (when created) - so dont want to react to any parent changes!
          
          //are atomic patch operations, and WILL react to parent edits!
          //desired for this specific data only!
          //i.e. a service is removed/added from parent recursion, want all children overrides to respond also!
          //i.e. new break added/removed/edited to parent recursion, want all children overrides to respond also!
          "services": [
            {
              "operation": "add",
              "service": "COVID:18+"
            },
            {
              "operation": "remove",
              "service": "FLU:18_64"
            }
          ],
          //adhoc block out time
          //edge cases of overlapping times with parent recurrence
          //how might this be displayed in UI...
          "exclusionTimes": [
            {
              "label": "One-off coffee",
              "operation": "add",
              "from": "13:15",
              "until": "13:30"
            },
            {
              //we are actually available for this break that exists in the main pattern!!
              //on this one day specifically!
              //edge cases with parent data shifting/editing, what do we want to happen!
              "operation": "remove",
              "from": "12:00",
              "until": "12:15"
            }
          ]
        }
      ]
    },
    {
      //a date with a small one-off block of time
      
      //minimalised structure with flattened session
      "date": "2026-09-30",
      //atomic...
      "exclusionTimes": [
        {
          "label": "One-off coffee",
          "operation": "add",
          "from": "13:15",
          "until": "13:30"
        }
      ]
    },
    {
