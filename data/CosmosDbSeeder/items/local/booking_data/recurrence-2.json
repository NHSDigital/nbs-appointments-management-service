  "site": "6877d86e-c2df-4def-8508-e1eccf0ea6be",
  "docType": "recurrence",
  
  //limited to 3 months to prevent messiness!!
  "from": "2026-08-20",
  "until": "2026-10-08",

  //keep template explicit and similar to RRule properties
  //means can be extended if other recurrences needed
  "recurrencePattern": {
    "frequency": "Weekly", 
    "interval": 1, //repeats every week (i.e when value = 2 would be every other week)
    "byDay": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ]
  },

  //why an array?
  //can we flatten??
  "sessions": [
    {
      "from": "09:00",
      "until": "17:00",
      "services": [
        "COVID:5_11",
        "RSV:Adult",
        "FLU:18_64",
        "COVID:18+"
      ],
      "slotLength": 10,
      "capacity": 5,
      // these are "breaks" - predefined session gaps on main recurrence rule
      //this is LIKE an exception rule, but not quite and matches our current data model
      //for managing slots implicitly
      //the from and until need to match the slot times
      //overlap allowed??
      "exceptions": [
        {
          "from": "10:00",
          "until": "10:15"
        },
        {
          "from": "12:00",
          "until": "12:15"
        },
        {
          "from": "14:00",
          "until": "16:00"
        }
      ]
    }
  ],
  
  //WE ARE NOT PERMITTING EXRULES within the exceptions data pattern
  //i.e you cannot define a new nested recursion that overrides the parent for a specific date range
  
  //exceptions should be ideally listed in chronological date order
  //only one exception per date allowed, changes should upsert existing record and not create new ones
  
  //in UI ,could display these in two different sections
  //section 1 = exceptions (no session days)
  //section 2 = overrides (days where the session exists but is different)
  
  //exclusions and overrides?? names?
  
  //Can we allow exception date range...? (minimal ExRule...?)
  //would we prevent overlaps?? (i.e two range/individual days intersecting)
  //would rather not if we can help it...
  "exceptions": [
    {
      "date": "2026-08-22",
      //empty session represents blocked out day for this occurrence
      "sessions": []
    },
    {
      "date": "2026-08-23",
      "sessions": []
    },
    {
      "date": "2026-08-24",
      "sessions": []
    },
    {
      //ATOMIC CHANGE FROM PARENT RECURRENCE??
      //means will auto update on any parent changes
      
      //how do you distinguish between exceptions that SHOULD follow parent data
      //OR
      //exceptions that should exist and be managed on their own merit??
      
      //is the fact that they are linked indication that they should follow??
      //i.e if you DONT want it to follow, remove it and make a new session/recurrence that won't follow
      "date": "2026-08-30",
      "sessions": [
        {
          //with this pattern, may still need to question whether to keep change linked (listed here)
          //or
          //unlinked (split out into new unrelated session)
          
          //OR 
          
          //keep cloned pattern and simply asking to apply to children when make service/break changes to parent??
          
          
          //cloned and static, WON'T react to parent!
          "from": "10:00",
          "until": "15:00",
          "slotLength": 10,
          "capacity": 2,
          
          //are atomic patch operations, WILL react to parent edits!
          "services": [
            "-FLU:18_64",
            "+COVID:18+"
          ],
          "exceptions": [
            {
              //add this new one-off break.
              //may merge with existing breaks to make one large unioned break?
              //how would we handle naming on merges??
              "type": "add",
              "from": "13:15",
              "until": "13:30"
            },
            {
              //if an exception in the parent lists this data exactly, remove it for this one-off
              "type": "remove",
              "from": "12:00",
              "until": "12:15"
            }
          ]
        }
      ]
    }
  ],
  
