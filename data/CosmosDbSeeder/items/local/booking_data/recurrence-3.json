  //if someone adds an exclusion date, REMOVE affected override on that date (so that if this exclusion is undone, the override doesn't come back!)
  //i.e. exclusionDate takes precedence over an override
  //these are overrides with no sessions on that day
  
  //once a date is excluded, only way to bring it back is to remove that exclusion instance in recursion
  //can then add override to new date if desired...
  
  "exclusionDates": ["2026-08-22", "2026-08-23", "2026-08-24"],
  
  //this is an EXRULE... danger zone!!
  //how will this respond to overlapping dates/ranges?
  
  //unionised exclusions aren't THAT bad as the outcome is the same, no availability on these dates
  //i.e sequencing does not matter as the operations are identical!
  //i.e. A then B <=> B then A
  "exclusionDateRanges": [
    {
      "label": "Easter Break",
      "from": "2026-08-22",
      "until": "2026-09-06"
    },
    {
      //do we even care about union overlapping??
